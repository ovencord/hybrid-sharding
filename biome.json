{
    "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
    "files": {
        "ignoreUnknown": true
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120,
        "lineEnding": "lf"
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noExplicitAny": "off",
                "noUnsafeDeclarationMerging": "off",
                "noImplicitAnyLet": "off",
                "noAssignInExpressions": "off",
                "useIterableCallbackReturn": "off"
            },
            "security": {
                "noGlobalEval": "off"
            },
            "style": {
                "useImportType": "error",
                "noNonNullAssertion": "off"
            },
            "correctness": {
                "noUnusedVariables": "error",
                "noUnusedImports": "error"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "trailingCommas": "all",
            "semicolons": "always"
        }
    },
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    }
}
